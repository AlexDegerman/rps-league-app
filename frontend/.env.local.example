# Core API Connection
# Local development: http://localhost:5000
# Production: https://your-backend-url.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Observability & Error Tracking
# Public Sentry DSN for client-side crash reporting and performance monitoring
# Find in: Sentry Project Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o12345.ingest.sentry.io/project-id

# Sentry Configuration
# Organization and Project slug found in Sentry general settings
NEXT_PUBLIC_SENTRY_ORG=your_sentry_org
NEXT_PUBLIC_SENTRY_PROJECT=your_sentry_project