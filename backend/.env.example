# Database & Security
# Supabase session pooler connection string (Get connected > Direct > Session pooler)
DATABASE_URL=your_supabase_connection_string_here
CORS_ORIGIN=http://localhost:3000

# Infrastructure Automation
# Secret key for authorizing GitHub Actions resets (Generate: openssl rand -hex 32)
RESET_SECRET=your_long_random_secret_here

# AI Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Observability (Optional)
# Discord webhook for administrative audit logging
DISCORD_LOG_WEBHOOK=your_discord_webhook_url_here