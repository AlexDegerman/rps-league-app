# Database & Security
CORS_ORIGIN=http://localhost:3000
# Supabase transaction pooler connection string
# Get from: Supabase Dashboard > Connect > Connection pooling > Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# Infrastructure Automation
# Secret key for authorizing GitHub Actions resets (Generate: openssl rand -hex 32)
RESET_SECRET=your_long_random_secret_here

# AI Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Observability & Operations
# Sentry DSN for full-stack error tracking and performance monitoring
SENTRY_DSN=https://your-dsn-key@o12345.ingest.sentry.io/project-id

# Discord Webhooks for real-time live-service monitoring
# LOG_WEBHOOK handles AI Oracle audit logs
# FEEDBACK_WEBHOOK handles user-submitted bugs and suggestions
DISCORD_LOG_WEBHOOK=your_discord_webhook_url_here
DISCORD_FEEDBACK_WEBHOOK=your_discord_feedback_webhook_url_here

# Admin secret key for managing one-click feedback bans (Generate: openssl rand -hex 32)
FEEDBACK_ADMIN_KEY=your_random_admin_secret_here